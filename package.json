    "react-native-orientation-locker": "^1.7.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.11.1",
    "react-native-size-matters": "^0.4.2",
    "react-native-svg": "^15.12.1"
