# Copy to .env and adjust. All values are optional — these are the defaults.

# WebSocket port the app connects to (must match the app's .env WS_PORT).
WS_PORT=8085

# Interface to bind. 0.0.0.0 lets a phone on the same Wi-Fi reach the server.
WS_HOST=0.0.0.0

# true  = virtual car, no hardware needed (default, safe for dev/CI/Docker)
# false = talk to a real Arduino over the serial port below
SIMULATE=true

# Only used when SIMULATE=false. Override with your device's path.
#   Linux: /dev/ttyUSB0   macOS: /dev/tty.usbserial*   Windows: COM3
SERIAL_PATH=/dev/ttyUSB0
SERIAL_BAUD=19200

# Logging. Levels: debug | info | warn | error (default info).
LOG_LEVEL=info
# Verbose tracing: log every frame on both legs (each app->car command with the
# client that sent it, and each car->app telemetry frame), decoded to its name.
# Implies debug-level output. Same as `npm run dev:verbose` / passing --verbose.
VERBOSE=false
# Directory for JSON-lines log files (rotated daily). Set empty to log to
# console only. Status + recent logs are also served at GET /health and
# GET /logs?limit=200&level=warn on the same port (LAN-only, unauthenticated).
LOG_DIR=logs
